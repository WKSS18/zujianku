{
  "name": "@test111190909222/hooks",
  "version": "5.0.0",
  "description": "Shared React hooks for SC component library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "dependencies": {
    "@test111190909222/utils": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "http://localhost:8080/"
  },
  "sideEffects": false
}
