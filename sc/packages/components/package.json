    "dev": "tsdown --watch"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17",
    "antd": ">=5",
    "@ant-design/x": ">=2"
  },
  "dependencies": {
    "@test111190909222/hooks": "workspace:*",
    "@test111190909222/utils": "workspace:*",
    "@test111190909222/theme": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "http://localhost:8080/"
  },
  "sideEffects": false
